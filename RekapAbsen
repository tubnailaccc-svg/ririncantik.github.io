<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rekap Absen Otomatis (Dengan Notifikasi)</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }
        body {
            background: #f4f7fc;
            display: flex;
            justify-content: center;
            padding: 30px 15px;
        }
        .container {
            max-width: 1400px;
            width: 100%;
            background: white;
            padding: 30px 25px;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        }
        h1 {
            font-size: 24px;
            margin-top: 0;
            margin-bottom: 6px;
            color: #1a2634;
        }
        .sub {
            color: #4a5a6e;
            margin-bottom: 25px;
            font-size: 14px;
        }
        .upload-area {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 14px 20px;
            background: #f8faff;
            padding: 18px 22px;
            border-radius: 12px;
            border: 1.5px dashed #b3c9e0;
            margin-bottom: 28px;
        }
        .upload-area input[type="file"] {
            flex: 1;
            min-width: 220px;
            padding: 8px 0;
        }
        .btn {
            background: #1a5f9e;
            color: white;
            border: none;
            padding: 10px 28px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn:hover {
            background: #0e4a7c;
        }
        .btn-copy {
            background: #1f7b4d;
        }
        .btn-copy:hover {
            background: #14633b;
        }
        .btn-reset {
            background: #7a8a9e;
        }
        .btn-reset:hover {
            background: #5f6e80;
        }

        .toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin: 18px 0 10px 0;
            align-items: center;
        }

        .table-wrapper {
            overflow-x: auto;
            margin-top: 8px;
            border-radius: 10px;
            border: 1px solid #dde5ef;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            font-size: 13px;
            background: white;
            min-width: 800px;
        }
        th {
            background: #1f2b38;
            color: white;
            font-weight: 600;
            padding: 10px 6px;
            text-align: center;
            border: 1px solid #2d3c4b;
            white-space: nowrap;
        }
        th.date-header {
            background: #2a3a4a;
            font-size: 12px;
        }
        th .sub-label {
            font-weight: 400;
            font-size: 10px;
            color: #b0c7dd;
        }
        td {
            padding: 8px 6px;
            border: 1px solid #d0dbe8;
            text-align: center;
            vertical-align: middle;
            background: white;
        }
        td:first-child {
            font-weight: 600;
            text-align: left;
            padding-left: 12px;
            background: #f9fcff;
        }
        td:nth-child(2) {
            text-align: center;
            background: #f9fcff;
        }
        .in-cell {
            color: #0a6b3a;
            font-weight: 600;
        }
        .out-cell {
            color: #b13a3a;
            font-weight: 600;
        }
        .empty-cell {
            color: #b0bcc8;
        }

        .status-msg {
            margin: 14px 0 0 0;
            padding: 10px 16px;
            border-radius: 8px;
            background: #eaf3fa;
            color: #1f4970;
            font-size: 14px;
        }
        .status-msg.error {
            background: #fde8e8;
            color: #9e2d2d;
        }
        .hidden {
            display: none !important;
        }

        .footer-note {
            margin-top: 18px;
            color: #4d637c;
            font-size: 13px;
            border-top: 1px solid #e2eaf2;
            padding-top: 16px;
        }
        .footer-note kbd {
            background: #ecf1f7;
            padding: 2px 10px;
            border-radius: 6px;
            font-size: 12px;
            border: 1px solid #c6d3e2;
        }

        /* ===== MODAL POP-UP ===== */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal-box {
            background: white;
            padding: 30px 35px;
            border-radius: 16px;
            max-width: 550px;
            width: 95%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: modalFade 0.3s ease;
        }
        @keyframes modalFade {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .modal-box h2 {
            margin-top: 0;
            color: #c0392b;
            font-size: 20px;
        }
        .modal-box .info {
            background: #f0f4fa;
            padding: 12px 16px;
            border-radius: 8px;
            margin: 12px 0 16px 0;
            font-size: 14px;
        }
        .modal-box .info strong {
            display: inline-block;
            min-width: 80px;
        }
        .modal-box .options {
            margin: 16px 0;
            max-height: 250px;
            overflow-y: auto;
        }
        .modal-box .options label {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border-radius: 8px;
            border: 1.5px solid #e2eaf2;
            margin-bottom: 6px;
            cursor: pointer;
            transition: 0.2s;
        }
        .modal-box .options label:hover {
            background: #f0f7ff;
            border-color: #1a5f9e;
        }
        .modal-box .options label.selected {
            background: #e3effa;
            border-color: #1a5f9e;
        }
        .modal-box .options label input[type="radio"] {
            width: 18px;
            height: 18px;
            accent-color: #1a5f9e;
            flex-shrink: 0;
        }
        .modal-box .options label .time-badge {
            font-weight: 600;
            font-size: 16px;
            color: #1a2634;
            min-width: 60px;
        }
        .modal-box .options label .status-badge {
            font-size: 12px;
            color: #4a5a6e;
            background: #edf2f7;
            padding: 2px 10px;
            border-radius: 20px;
        }
        .modal-box .options label .role-select {
            margin-left: auto;
            padding: 4px 10px;
            border-radius: 6px;
            border: 1px solid #d0dbe8;
            background: white;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }
        .modal-box .options label .role-select:focus {
            outline: 2px solid #1a5f9e;
        }
        .modal-box .btn-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 18px;
        }
        .modal-box .btn-group .btn-modal {
            padding: 10px 20px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: 0.2s;
            flex: 1;
            min-width: 100px;
        }
        .modal-box .btn-group .btn-primary {
            background: #1a5f9e;
            color: white;
        }
        .modal-box .btn-group .btn-primary:hover {
            background: #0e4a7c;
        }
        .modal-box .btn-group .btn-secondary {
            background: #e2eaf2;
            color: #1a2634;
        }
        .modal-box .btn-group .btn-secondary:hover {
            background: #d0dbe8;
        }
        .modal-box .btn-group .btn-danger {
            background: #c0392b;
            color: white;
        }
        .modal-box .btn-group .btn-danger:hover {
            background: #a93226;
        }
        .modal-box .btn-group .btn-success {
            background: #1f7b4d;
            color: white;
        }
        .modal-box .btn-group .btn-success:hover {
            background: #14633b;
        }
        @media (max-width: 500px) {
            .modal-box {
                padding: 20px;
            }
            .modal-box .btn-group .btn-modal {
                min-width: 100%;
            }
            .modal-box .options label {
                flex-wrap: wrap;
            }
            .modal-box .options label .role-select {
                margin-left: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📋 Rekap Absen Otomatis</h1>
        <div class="sub">Upload file Excel dari alat absen → langsung jadi tabel landscape siap copy ke kantor</div>

        <div class="upload-area">
            <input type="file" id="fileInput" accept=".xls,.xlsx" />
            <button class="btn" id="prosesBtn">▶ Proses</button>
            <button class="btn btn-reset" id="resetBtn">↺ Reset</button>
        </div>

        <div id="statusMsg" class="status-msg hidden"></div>

        <div id="resultArea" class="hidden">
            <div class="toolbar">
                <button class="btn btn-copy" id="copyBtn">📋 Copy Tabel</button>
                <span style="font-size:13px; color:#3f5a77;">⬅️ Klik Copy, lalu paste ke Excel (Ctrl+V)</span>
            </div>
            <div class="table-wrapper" id="tableWrapper">
                <!-- tabel akan di-render di sini -->
            </div>
            <div class="footer-note">
                💡 <kbd>Ctrl+A</kbd> pilih semua, <kbd>Ctrl+C</kbd> copy, lalu <kbd>Ctrl+V</kbd> di Excel.
            </div>
        </div>
    </div>

    <!-- ===== MODAL POP-UP ===== -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal-box">
            <h2>⚠️ Perlu Konfirmasi</h2>
            <div class="info" id="modalInfo">
                <strong>Karyawan:</strong> <span id="modalNama">-</span><br />
                <strong>Tanggal :</strong> <span id="modalTgl">-</span>
            </div>
            <p style="margin: 6px 0 10px 0; font-size:14px; color:#4a5a6e;">Pilih data dan tentukan sebagai MASUK atau KELUAR:</p>
            <div class="options" id="modalOptions">
                <!-- diisi dari JavaScript -->
            </div>
            <div class="btn-group">
                <button class="btn-modal btn-success" id="modalConfirm">✅ Pakai yang dipilih</button>
                <button class="btn-modal btn-secondary" id="modalSkip">⏭️ Lewati</button>
                <button class="btn-modal btn-danger" id="modalCancel">❌ Batal</button>
            </div>
        </div>
    </div>

    <!-- pakai SheetJS (XLSX) dari CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js">
    </script>
    <script>
        (function() {
            // ----- DOM refs -----
            const fileInput = document.getElementById('fileInput');
            const prosesBtn = document.getElementById('prosesBtn');
            const resetBtn = document.getElementById('resetBtn');
            const copyBtn = document.getElementById('copyBtn');
            const statusMsg = document.getElementById('statusMsg');
            const resultArea = document.getElementById('resultArea');
            const tableWrapper = document.getElementById('tableWrapper');

            // Modal
            const modalOverlay = document.getElementById('modalOverlay');
            const modalNama = document.getElementById('modalNama');
            const modalTgl = document.getElementById('modalTgl');
            const modalOptions = document.getElementById('modalOptions');
            const modalConfirm = document.getElementById('modalConfirm');
            const modalSkip = document.getElementById('modalSkip');
            const modalCancel = document.getElementById('modalCancel');

            // ----- state untuk modal -----
            let pendingResolve = null;
            let selectedData = null;

            // ----- helpers -----
            function showStatus(text, isError) {
                statusMsg.classList.remove('hidden', 'error');
                statusMsg.textContent = text;
                if (isError) statusMsg.classList.add('error');
            }

            function hideStatus() {
                statusMsg.classList.add('hidden');
            }

            function resetUI() {
                hideStatus();
                resultArea.classList.add('hidden');
                tableWrapper.innerHTML = '';
                fileInput.value = '';
                if (modalOverlay.classList.contains('active')) {
                    modalOverlay.classList.remove('active');
                    if (pendingResolve) {
                        pendingResolve(null);
                        pendingResolve = null;
                    }
                }
            }

            // ----- FUNGSI MODAL (dengan pilihan role Masuk/Keluar per item) -----
            function showModalWithRoles(nama, tgl, items, title = '⚠️ Perlu Konfirmasi') {
                return new Promise((resolve) => {
                    document.querySelector('.modal-box h2').textContent = title;
                    modalNama.textContent = nama;
                    modalTgl.textContent = tgl;

                    modalOptions.innerHTML = '';
                    items.forEach((item, idx) => {
                        const label = document.createElement('label');
                        const radio = document.createElement('input');
                        radio.type = 'radio';
                        radio.name = 'modalChoice';
                        radio.value = idx;
                        if (idx === 0) radio.checked = true;

                        const timeSpan = document.createElement('span');
                        timeSpan.className = 'time-badge';
                        timeSpan.textContent = item.time;

                        const statusSpan = document.createElement('span');
                        statusSpan.className = 'status-badge';
                        statusSpan.textContent = item.originalStatus || '';

                        // Dropdown untuk pilih Masuk/Keluar
                        const select = document.createElement('select');
                        select.className = 'role-select';
                        select.dataset.idx = idx;
                        const optIn = document.createElement('option');
                        optIn.value = 'in';
                        optIn.textContent = '→ Masuk';
                        const optOut = document.createElement('option');
                        optOut.value = 'out';
                        optOut.textContent = '→ Keluar';

                        // Default: kalo jam <= 12:00 → Masuk, kalo > 12:00 → Keluar
                        const jam = parseInt(item.time.split(':')[0]);
                        if (jam <= 12) {
                            optIn.selected = true;
                        } else {
                            optOut.selected = true;
                        }

                        select.appendChild(optIn);
                        select.appendChild(optOut);

                        label.appendChild(radio);
                        label.appendChild(timeSpan);
                        label.appendChild(statusSpan);
                        label.appendChild(select);

                        // Klik label -> pilih radio
                        label.addEventListener('click', function(e) {
                            // Jangan trigger kalo klik di select
                            if (e.target.tagName === 'SELECT') return;
                            const r = this.querySelector('input[type="radio"]');
                            if (r) {
                                r.checked = true;
                                document.querySelectorAll('.modal-box .options label').forEach(l => l
                                    .classList.remove('selected'));
                                this.classList.add('selected');
                            }
                        });

                        // Select juga bisa dipilih tanpa mengganggu radio
                        select.addEventListener('click', function(e) {
                            e.stopPropagation();
                        });

                        modalOptions.appendChild(label);
                    });

                    // Highlight yang pertama
                    const firstLabel = modalOptions.querySelector('label');
                    if (firstLabel) firstLabel.classList.add('selected');

                    pendingResolve = resolve;
                    selectedData = null;

                    modalOverlay.classList.add('active');
                });
            }

            // ----- FUNGSI MODAL biasa (tanpa role) untuk kasus lain -----
            function showModalSimple(nama, tgl, options, title = '⚠️ Perlu Konfirmasi') {
                return new Promise((resolve) => {
                    document.querySelector('.modal-box h2').textContent = title;
                    modalNama.textContent = nama;
                    modalTgl.textContent = tgl;

                    modalOptions.innerHTML = '';
                    options.forEach((opt, idx) => {
                        const label = document.createElement('label');
                        const radio = document.createElement('input');
                        radio.type = 'radio';
                        radio.name = 'modalChoice';
                        radio.value = idx;
                        if (idx === 0) radio.checked = true;

                        const span = document.createElement('span');
                        span.className = 'time-badge';
                        span.textContent = opt.label;

                        const badge = document.createElement('span');
                        badge.className = 'status-badge';
                        badge.textContent = opt.sub || '';

                        label.appendChild(radio);
                        label.appendChild(span);
                        label.appendChild(badge);

                        label.addEventListener('click', function(e) {
                            const r = this.querySelector('input[type="radio"]');
                            if (r) {
                                r.checked = true;
                                document.querySelectorAll('.modal-box .options label').forEach(l => l
                                    .classList.remove('selected'));
                                this.classList.add('selected');
                            }
                        });

                        modalOptions.appendChild(label);
                    });

                    const firstLabel = modalOptions.querySelector('label');
                    if (firstLabel) firstLabel.classList.add('selected');

                    pendingResolve = resolve;
                    selectedData = null;

                    modalOverlay.classList.add('active');
                });
            }

            // ----- Event listener modal -----
            function closeModal(result) {
                modalOverlay.classList.remove('active');
                if (pendingResolve) {
                    pendingResolve(result);
                    pendingResolve = null;
                }
            }

            modalConfirm.addEventListener('click', function() {
                const selected = document.querySelector('input[name="modalChoice"]:checked');
                if (selected) {
                    const idx = parseInt(selected.value);
                    const labels = modalOptions.querySelectorAll('label');
                    if (labels[idx]) {
                        const timeText = labels[idx].querySelector('.time-badge')?.textContent || '';
                        const select = labels[idx].querySelector('.role-select');
                        let role = 'in';
                        if (select) {
                            role = select.value;
                        }
                        closeModal({ time: timeText, role: role });
                    } else {
                        closeModal(null);
                    }
                } else {
                    closeModal(null);
                }
            });

            modalSkip.addEventListener('click', function() {
                closeModal('__SKIP__');
            });

            modalCancel.addEventListener('click', function() {
                closeModal('__CANCEL__');
            });

            // ===== FUNGSI FORMAT JAM (AMAN) =====
            function formatJam(jam) {
                if (!jam) return null;
                // Kalo udah string, langsung proses
                if (typeof jam === 'string') {
                    const parts = jam.split(':');
                    if (parts.length >= 2) {
                        return parts[0] + ':' + parts[1];
                    }
                    return jam;
                }
                // Kalo object (dari modal), ambil .time
                if (typeof jam === 'object' && jam !== null && jam.time) {
                    const parts = jam.time.split(':');
                    if (parts.length >= 2) {
                        return parts[0] + ':' + parts[1];
                    }
                    return jam.time;
                }
                return null;
            }

            // ----- logika utama (dengan modal) -----
            async function processExcel(data) {
                const sheet = data.Sheets[data.SheetNames[0]];
                const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

                if (!rows || rows.length < 2) {
                    showStatus('❌ File kosong atau tidak sesuai.', true);
                    return null;
                }

                // cari header
                const header = rows[0];
                let idxNama = -1,
                    idxTgl = -1,
                    idxStatus = -1,
                    idxId = -1;
                header.forEach((col, i) => {
                    const c = String(col || '').toLowerCase().trim();
                    if (c === 'nama') idxNama = i;
                    else if (c === 'tgl/waktu' || c === 'tgl_waktu' || c === 'tanggal') idxTgl = i;
                    else if (c === 'status') idxStatus = i;
                    else if (c === 'no.id' || c === 'no id' || c === 'id') idxId = i;
                });

                if (idxNama === -1) idxNama = 1;
                if (idxTgl === -1) idxTgl = 3;
                if (idxStatus === -1) idxStatus = 4;

                if (idxNama === -1 || idxTgl === -1 || idxStatus === -1) {
                    showStatus('❌ Header tidak dikenali. Pastikan kolom: Nama, Tgl/Waktu, Status.', true);
                    return null;
                }

                // parse data
                const empMap = new Map();

                for (let i = 1; i < rows.length; i++) {
                    const row = rows[i];
                    if (!row || row.length === 0) continue;
                    const nama = String(row[idxNama] || '').trim();
                    if (!nama || nama === '' || nama === 'Departemen') continue;

                    const tglWaktu = String(row[idxTgl] || '').trim();
                    if (!tglWaktu) continue;
                    const parts = tglWaktu.split(' ');
                    if (parts.length < 2) continue;
                    const tgl = parts[0].trim();
                    const jamRaw = parts[1].trim();
                    const jam = jamRaw.replace(/\./g, ':');

                    const status = String(row[idxStatus] || '').trim();
                    let id = '';
                    if (idxId !== -1 && row[idxId] !== undefined && row[idxId] !== null) {
                        id = String(row[idxId]).trim();
                    }

                    const key = nama + '|' + id;

                    if (!empMap.has(key)) {
                        empMap.set(key, {
                            nama: nama,
                            id: id,
                            data: {}
                        });
                    }
                    const emp = empMap.get(key);

                    if (!emp.data[tgl]) {
                        emp.data[tgl] = { masuk: [], keluar: [] };
                    }

                    if (status.includes('Masuk')) {
                        emp.data[tgl].masuk.push(jam);
                    } else if (status.includes('Keluar')) {
                        emp.data[tgl].keluar.push(jam);
                    }
                }

                if (empMap.size === 0) {
                    showStatus('❌ Tidak ada data karyawan yang terbaca.', true);
                    return null;
                }

                // ===== PROSES DENGAN MODAL =====
                const result = [];
                const allDates = new Set();

                for (const [key, emp] of empMap) {
                    const rowData = {
                        nama: emp.nama,
                        id: emp.id,
                        dates: {}
                    };

                    for (const [tgl, logs] of Object.entries(emp.data)) {
                        allDates.add(tgl);

                        let masuk = [...logs.masuk];
                        let keluar = [...logs.keluar];

                        // --- Tentukan IN ---
                        let inTime = null;
                        let outTime = null;

                        // KASUS 1: Ada C/Masuk
                        if (masuk.length > 0) {
                            const sortedIn = masuk.slice().sort();
                            if (sortedIn.length > 1) {
                                const options = sortedIn.map((j) => ({
                                    label: j,
                                    sub: 'C/Masuk'
                                }));
                                const pilihan = await showModalSimple(
                                    emp.nama,
                                    tgl,
                                    options,
                                    '⚠️ Pilih Jam Masuk (C/Masuk Ganda)'
                                );

                                if (pilihan === '__SKIP__' || pilihan === '__CANCEL__' || pilihan === null) {
                                    inTime = null;
                                } else {
                                    inTime = pilihan;
                                }
                            } else {
                                inTime = sortedIn[0];
                            }
                        }

                        // KASUS 2: Ga ada C/Masuk sama sekali → semua data adalah C/Keluar
                        if (masuk.length === 0 && keluar.length > 0) {
                            const items = keluar.map((j) => ({
                                time: j,
                                originalStatus: 'C/Keluar'
                            }));

                            const pilihan = await showModalWithRoles(
                                emp.nama,
                                tgl,
                                items,
                                '⚠️ Tidak ada C/Masuk! Tentukan status tiap jam:'
                            );

                            if (pilihan === '__SKIP__' || pilihan === '__CANCEL__' || pilihan === null) {
                                inTime = null;
                                outTime = null;
                            } else {
                                // pilihan = { time: '01:46', role: 'in' } atau 'out'
                                if (pilihan.role === 'in') {
                                    inTime = pilihan.time;
                                } else {
                                    outTime = pilihan.time;
                                }
                                // Hapus dari keluar
                                keluar = keluar.filter(j => j !== pilihan.time);
                            }
                        }

                        // KASUS 3: Ada C/Masuk, tapi perlu cari OUT
                        if (inTime !== null) {
                            // Cari OUT dari C/Keluar
                            if (keluar.length > 0) {
                                const sortedOut = keluar.slice().sort();
                                if (sortedOut.length > 1) {
                                    const options = sortedOut.map((j) => ({
                                        label: j,
                                        sub: 'C/Keluar'
                                    }));
                                    const pilihan = await showModalSimple(
                                        emp.nama,
                                        tgl,
                                        options,
                                        '⚠️ Pilih Jam Keluar (C/Keluar Ganda)'
                                    );

                                    if (pilihan === '__SKIP__' || pilihan === '__CANCEL__' || pilihan === null) {
                                        outTime = null;
                                    } else {
                                        outTime = pilihan;
                                    }
                                } else {
                                    outTime = sortedOut[0];
                                }
                            }

                            // Kalo ga ada C/Keluar, cari C/Masuk sore (≥ 12:00) sebagai OUT
                            if (outTime === null && masuk.length > 0) {
                                const masukSore = masuk.filter(j => {
                                    const jam = parseInt(j.split(':')[0]);
                                    return jam >= 12;
                                });

                                if (masukSore.length > 0) {
                                    const options = masukSore.map((j) => ({
                                        label: j,
                                        sub: 'C/Masuk (sore) → dijadikan Keluar?'
                                    }));
                                    const pilihan = await showModalSimple(
                                        emp.nama,
                                        tgl,
                                        options,
                                        '⚠️ Tidak ada C/Keluar, gunakan C/Masuk sore?'
                                    );

                                    if (pilihan === '__SKIP__' || pilihan === '__CANCEL__' || pilihan === null) {
                                        outTime = null;
                                    } else {
                                        outTime = pilihan;
                                    }
                                }
                            }
                        }

                        // ===== FORMAT JAM (PAKAI FUNGSI AMAN) =====
                        const inFormatted = formatJam(inTime);
                        const outFormatted = formatJam(outTime);

                        rowData.dates[tgl] = { in: inFormatted, out: outFormatted };
                    }

                    result.push(rowData);
                }

                const sortedDates = Array.from(allDates).sort((a, b) => {
                    const da = a.split('/');
                    const db = b.split('/');
                    return new Date(da[2], da[1] - 1, da[0]) - new Date(db[2], db[1] - 1, db[0]);
                });

                return { data: result, dates: sortedDates };
            }

            // ----- render tabel (In & Out terpisah) -----
            function renderTable(processed) {
                if (!processed || !processed.data || processed.data.length === 0) {
                    showStatus('❌ Tidak ada data untuk ditampilkan.', true);
                    return;
                }

                const { data, dates } = processed;

                let html = '<table>\n<thead>\n<tr>';
                html += '<th>Nama</th>';
                html += '<th>No.ID</th>';
                for (const tgl of dates) {
                    html += `<th class="date-header" colspan="2">${tgl}</th>`;
                }
                html += '</tr>\n<tr>';
                html += '<th style="background:#2a3a4a;"></th>';
                html += '<th style="background:#2a3a4a;"></th>';
                for (const tgl of dates) {
                    html += `<th style="background:#2a3a4a;font-weight:400;font-size:11px;color:#b0c7dd;">In</th>`;
                    html += `<th style="background:#2a3a4a;font-weight:400;font-size:11px;color:#b0c7dd;">Out</th>`;
                }
                html += '</tr>\n</thead>\n<tbody>\n';

                for (const emp of data) {
                    html += '<tr>';
                    html += `<td>${emp.nama}</td>`;
                    html += `<td>${emp.id || '-'}</td>`;

                    for (const tgl of dates) {
                        const d = emp.dates[tgl] || { in: null, out: null };
                        const inVal = d.in ? `<span class="in-cell">${d.in}</span>` :
                            `<span class="empty-cell">-</span>`;
                        const outVal = d.out ? `<span class="out-cell">${d.out}</span>` :
                            `<span class="empty-cell">-</span>`;
                        html += `<td>${inVal}</td>`;
                        html += `<td>${outVal}</td>`;
                    }

                    html += '</tr>\n';
                }

                html += '</tbody>\n</table>';
                tableWrapper.innerHTML = html;

                resultArea.classList.remove('hidden');
                hideStatus();
                showStatus(`✅ Berhasil! ${data.length} karyawan, ${dates.length} hari.`);
            }

            // ----- main proses (async) -----
            async function handleFile() {
                const file = fileInput.files[0];
                if (!file) {
                    showStatus('⚠️ Pilih file Excel terlebih dahulu.', true);
                    return;
                }

                const reader = new FileReader();
                reader.onload = async function(e) {
                    try {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, { type: 'array' });
                        const processed = await processExcel(workbook);
                        if (processed) {
                            renderTable(processed);
                        }
                    } catch (err) {
                        showStatus('❌ Gagal membaca file: ' + err.message, true);
                        console.error(err);
                    }
                };
                reader.readAsArrayBuffer(file);
            }

            // ----- copy ke clipboard -----
            function copyTable() {
                const table = tableWrapper.querySelector('table');
                if (!table) {
                    showStatus('⚠️ Tidak ada tabel untuk di-copy.', true);
                    return;
                }

                let text = '';
                const rows = table.querySelectorAll('tr');
                for (const row of rows) {
                    const cells = row.querySelectorAll('th, td');
                    const rowText = [];
                    for (const cell of cells) {
                        let cellText = cell.innerText.trim();
                        cellText = cellText.replace(/\s+/g, ' ');
                        rowText.push(cellText);
                    }
                    text += rowText.join('\t') + '\n';
                }

                navigator.clipboard.writeText(text).then(() => {
                    showStatus('✅ Tabel berhasil di-copy! Langsung paste ke Excel (Ctrl+V).');
                }).catch(() => {
                    const ta = document.createElement('textarea');
                    ta.value = text;
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    ta.remove();
                    showStatus('✅ Tabel berhasil di-copy! Langsung paste ke Excel (Ctrl+V).');
                });
            }

            // ----- event listeners -----
            prosesBtn.addEventListener('click', handleFile);

            resetBtn.addEventListener('click', function() {
                resetUI();
                hideStatus();
                showStatus('🔄 Siap upload file baru.');
            });

            copyBtn.addEventListener('click', copyTable);

            fileInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    prosesBtn.click();
                }
            });

            // drag & drop
            const container = document.querySelector('.container');
            container.addEventListener('dragover', function(e) {
                e.preventDefault();
                this.style.borderColor = '#1a5f9e';
            });
            container.addEventListener('dragleave', function(e) {
                e.preventDefault();
                this.style.borderColor = '';
            });
            container.addEventListener('drop', function(e) {
                e.preventDefault();
                this.style.borderColor = '';
                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    fileInput.files = files;
                    prosesBtn.click();
                }
            });

            showStatus('📂 Upload file Excel dari alat absen, lalu klik Proses.');
        })();
    </script>
</body>
</html>
